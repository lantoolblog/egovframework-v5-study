CREATE TABLE CUSTOMER(ID BIGINT GENERATED BY DEFAULT AS IDENTITY(START WITH 0) NOT NULL PRIMARY KEY,VERSION BIGINT,NAME VARCHAR(45),CREDIT DECIMAL(10,2))
